{
  "name": "visual-algo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @vsa/frontend dev",
    "build": "pnpm --filter @vsa/frontend build",
    "start": "node server.js",
    "lint": "eslint packages --ext .ts,.tsx",
    "format": "prettier --write \"packages/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,css,json}\"",
    "check": "pnpm lint && pnpm --filter @vsa/frontend exec tsc --noEmit",
    "backend": "pnpm --filter @vsa/backend dev"
  },
  "dependencies": {
    "@types/highlight.js": "^10.1.0",
    "cors": "^2.8.6",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "highlight.js": "^11.11.1"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^10.4.1"
  }
}
